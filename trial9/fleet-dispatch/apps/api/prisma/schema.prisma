generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN    @map("admin")
  DRIVER   @map("driver")
  DISPATCHER @map("dispatcher")
  VIEWER   @map("viewer")

  @@map("user_role")
}

enum VehicleStatus {
  AVAILABLE   @map("available")
  IN_USE      @map("in_use")
  MAINTENANCE @map("maintenance")
  RETIRED     @map("retired")

  @@map("vehicle_status")
}

enum DriverStatus {
  AVAILABLE   @map("available")
  ON_DUTY     @map("on_duty")
  OFF_DUTY    @map("off_duty")
  SUSPENDED   @map("suspended")

  @@map("driver_status")
}

enum DispatchStatus {
  PENDING     @map("pending")
  ASSIGNED    @map("assigned")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")
  CANCELLED   @map("cancelled")

  @@map("dispatch_status")
}

enum MaintenanceStatus {
  SCHEDULED  @map("scheduled")
  IN_PROGRESS @map("in_progress")
  COMPLETED  @map("completed")
  CANCELLED  @map("cancelled")

  @@map("maintenance_status")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(VIEWER)
  tenantId  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Vehicle {
  id           String        @id @default(uuid())
  licensePlate String        @map("license_plate")
  make         String
  model        String
  year         Int
  status       VehicleStatus @default(AVAILABLE)
  mileage      Int           @default(0)
  fuelCapacity Decimal       @db.Decimal(12, 2) @map("fuel_capacity")
  costPerMile  Decimal       @db.Decimal(12, 2) @map("cost_per_mile")
  tenantId     String
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  dispatches   Dispatch[]
  maintenances Maintenance[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@map("vehicles")
}

model Driver {
  id           String       @id @default(uuid())
  name         String
  email        String
  phone        String
  licenseNumber String      @map("license_number")
  status       DriverStatus @default(AVAILABLE)
  hourlyRate   Decimal      @db.Decimal(12, 2) @map("hourly_rate")
  tenantId     String
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  dispatches   Dispatch[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@map("drivers")
}

model Route {
  id           String   @id @default(uuid())
  name         String
  origin       String
  destination  String
  distanceMiles Decimal @db.Decimal(12, 2) @map("distance_miles")
  estimatedTime Int     @map("estimated_time")
  tenantId     String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dispatches   Dispatch[]

  @@index([tenantId])
  @@map("routes")
}

model Dispatch {
  id          String         @id @default(uuid())
  status      DispatchStatus @default(PENDING)
  scheduledAt DateTime       @map("scheduled_at")
  startedAt   DateTime?      @map("started_at")
  completedAt DateTime?      @map("completed_at")
  notes       String?
  totalCost   Decimal        @db.Decimal(12, 2) @default(0) @map("total_cost")
  vehicleId   String
  driverId    String
  routeId     String
  tenantId    String
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])
  driver      Driver  @relation(fields: [driverId], references: [id])
  route       Route   @relation(fields: [routeId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([vehicleId])
  @@index([driverId])
  @@index([routeId])
  @@map("dispatches")
}

model Maintenance {
  id          String            @id @default(uuid())
  description String
  status      MaintenanceStatus @default(SCHEDULED)
  scheduledAt DateTime          @map("scheduled_at")
  completedAt DateTime?         @map("completed_at")
  cost        Decimal           @db.Decimal(12, 2) @default(0)
  vehicleId   String
  tenantId    String
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([vehicleId])
  @@map("maintenances")
}
