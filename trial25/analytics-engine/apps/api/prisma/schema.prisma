generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN  @map("admin")
  EDITOR @map("editor")
  VIEWER @map("viewer")

  @@map("role")
}

enum SyncStatus {
  PENDING   @map("pending")
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")

  @@map("sync_status")
}

enum AuditAction {
  CREATE @map("create")
  UPDATE @map("update")
  DELETE @map("delete")
  LOGIN  @map("login")
  EXPORT @map("export")

  @@map("audit_action")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(VIEWER)
  tenantId     String   @map("tenant_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dashboards Dashboard[]
  auditLogs  AuditLog[]

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Dashboard {
  id          String   @id @default(uuid())
  name        String
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  tenantId    String   @map("tenant_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  widgets Widget[]

  @@index([tenantId])
  @@index([userId])
  @@map("dashboards")
}

model Widget {
  id          String   @id @default(uuid())
  title       String
  type        String
  config      Json     @default("{}")
  position    Int      @default(0)
  dashboardId String   @map("dashboard_id")
  tenantId    String   @map("tenant_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([dashboardId])
  @@map("widgets")
}

model DataSource {
  id               String   @id @default(uuid())
  name             String
  type             String
  connectionString String   @map("connection_string")
  tenantId         String   @map("tenant_id")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  syncHistories SyncHistory[]

  @@index([tenantId])
  @@map("data_sources")
}

model SyncHistory {
  id           String      @id @default(uuid())
  dataSourceId String      @map("data_source_id")
  status       SyncStatus  @default(PENDING)
  recordCount  Int         @default(0) @map("record_count")
  errorMessage String?     @map("error_message")
  tenantId     String      @map("tenant_id")
  startedAt    DateTime    @default(now()) @map("started_at")
  completedAt  DateTime?   @map("completed_at")

  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([dataSourceId])
  @@map("sync_histories")
}

model AuditLog {
  id        String      @id @default(uuid())
  action    AuditAction
  entity    String
  entityId  String      @map("entity_id")
  details   Json?
  userId    String      @map("user_id")
  tenantId  String      @map("tenant_id")
  createdAt DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}
