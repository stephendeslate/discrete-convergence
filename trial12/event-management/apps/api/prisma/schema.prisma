// TRACED: EM-DATA-001
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// TRACED: EM-DATA-002
enum UserRole {
  ADMIN     @map("admin")
  USER      @map("user")
  ORGANIZER @map("organizer")

  @@map("user_role")
}

// TRACED: EM-DATA-003
enum EventStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  CANCELLED @map("cancelled")
  COMPLETED @map("completed")

  @@map("event_status")
}

// TRACED: EM-DATA-004
enum TicketStatus {
  AVAILABLE @map("available")
  SOLD      @map("sold")
  CANCELLED @map("cancelled")
  REFUNDED  @map("refunded")

  @@map("ticket_status")
}

// TRACED: EM-DATA-005
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(USER)
  tenantId     String   @map("tenant_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  attendees Attendee[]

  @@index([tenantId])
  @@map("users")
}

// TRACED: EM-DATA-006
model Event {
  id          String      @id @default(uuid())
  title       String
  description String
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  status      EventStatus @default(DRAFT)
  capacity    Int
  tenantId    String      @map("tenant_id")
  venueId     String      @map("venue_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  venue     Venue      @relation(fields: [venueId], references: [id])
  schedules Schedule[]
  tickets   Ticket[]
  attendees Attendee[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([venueId])
  @@map("events")
}

// TRACED: EM-DATA-007
model Venue {
  id        String   @id @default(uuid())
  name      String
  address   String
  city      String
  capacity  Int
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  events Event[]

  @@index([tenantId])
  @@map("venues")
}

// TRACED: EM-DATA-008
model Schedule {
  id        String   @id @default(uuid())
  title     String
  speaker   String
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  room      String
  eventId   String   @map("event_id")
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id])

  @@index([tenantId])
  @@index([eventId])
  @@map("schedules")
}

// TRACED: EM-DATA-009
model Ticket {
  id       String       @id @default(uuid())
  price    Decimal      @db.Decimal(12, 2)
  type     String
  status   TicketStatus @default(AVAILABLE)
  eventId  String       @map("event_id")
  tenantId String       @map("tenant_id")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([eventId])
  @@map("tickets")
}

// TRACED: EM-DATA-010
model Attendee {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@index([tenantId])
  @@index([eventId])
  @@map("attendees")
}
