generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN      @map("admin")
  ORGANIZER  @map("organizer")
  VIEWER     @map("viewer")

  @@map("role")
}

enum SubscriptionTier {
  FREE       @map("free")
  PRO        @map("pro")
  ENTERPRISE @map("enterprise")

  @@map("subscription_tier")
}

enum EventStatus {
  DRAFT      @map("draft")
  PUBLISHED  @map("published")
  CANCELLED  @map("cancelled")
  COMPLETED  @map("completed")

  @@map("event_status")
}

enum TicketType {
  GENERAL    @map("general")
  VIP        @map("vip")
  EARLY_BIRD @map("early_bird")

  @@map("ticket_type")
}

enum CheckInStatus {
  REGISTERED   @map("registered")
  CHECKED_IN   @map("checked_in")
  NO_SHOW      @map("no_show")

  @@map("check_in_status")
}

model Tenant {
  id               String           @id @default(uuid())
  name             String
  subscriptionTier SubscriptionTier @default(FREE)
  brandColor       String?
  logoUrl          String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  users     User[]
  events    Event[]
  venues    Venue[]
  auditLogs AuditLog[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(VIEWER)
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Event {
  id          String      @id @default(uuid())
  title       String
  description String?
  status      EventStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime
  tenantId    String
  venueId     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  venue     Venue?     @relation(fields: [venueId], references: [id], onDelete: SetNull)
  tickets   Ticket[]
  attendees Attendee[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@map("events")
}

model Ticket {
  id        String     @id @default(uuid())
  type      TicketType @default(GENERAL)
  price     Decimal    @db.Decimal(12, 2)
  quantity  Int
  sold      Int        @default(0)
  eventId   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendees Attendee[]

  @@index([eventId])
  @@index([type])
  @@map("tickets")
}

model Attendee {
  id            String        @id @default(uuid())
  name          String
  email         String
  checkInStatus CheckInStatus @default(REGISTERED)
  eventId       String
  ticketId      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([ticketId])
  @@index([checkInStatus])
  @@index([eventId, checkInStatus])
  @@map("attendees")
}

model Venue {
  id        String   @id @default(uuid())
  name      String
  address   String
  capacity  Int
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events Event[]

  @@index([tenantId])
  @@map("venues")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  details   String?
  userId    String
  tenantId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, entity])
  @@map("audit_logs")
}
