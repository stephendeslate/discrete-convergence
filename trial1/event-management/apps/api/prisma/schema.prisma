generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ORGANIZER
  ATTENDEE

  @@map("user_role")
}

enum EventStatus {
  DRAFT            @map("DRAFT")
  PUBLISHED        @map("PUBLISHED")
  REGISTRATION_OPEN @map("REGISTRATION_OPEN")
  REGISTRATION_CLOSED @map("REGISTRATION_CLOSED")
  IN_PROGRESS      @map("IN_PROGRESS")
  COMPLETED        @map("COMPLETED")
  ARCHIVED         @map("ARCHIVED")
  CANCELLED        @map("CANCELLED")

  @@map("event_status")
}

enum RegistrationStatus {
  PENDING    @map("PENDING")
  CONFIRMED  @map("CONFIRMED")
  CANCELLED  @map("CANCELLED")
  WAITLISTED @map("WAITLISTED")
  CHECKED_IN @map("CHECKED_IN")

  @@map("registration_status")
}

enum VenueType {
  PHYSICAL @map("PHYSICAL")
  VIRTUAL  @map("VIRTUAL")
  HYBRID   @map("HYBRID")

  @@map("venue_type")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  events        Event[]
  venues        Venue[]
  registrations Registration[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  passwordHash   String   @map("password_hash")
  role           UserRole
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id])
  registrations Registration[]

  @@index([organizationId])
  @@map("users")
}

model Event {
  id             String      @id @default(uuid())
  name           String
  slug           String
  description    String?
  status         EventStatus @default(DRAFT)
  startDate      DateTime    @map("start_date")
  endDate        DateTime    @map("end_date")
  timezone       String      @default("UTC")
  organizationId String      @map("organization_id")
  venueId        String?     @map("venue_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id])
  venue         Venue?         @relation(fields: [venueId], references: [id])
  sessions      EventSession[]
  ticketTypes   TicketType[]
  registrations Registration[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, startDate])
  @@map("events")
}

model EventSession {
  id        String   @id @default(uuid())
  title     String
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  track     String?
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@map("event_sessions")
}

model Venue {
  id             String    @id @default(uuid())
  name           String
  address        String?
  capacity       Int
  type           VenueType @default(PHYSICAL)
  organizationId String    @map("organization_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  events       Event[]

  @@index([organizationId])
  @@map("venues")
}

model TicketType {
  id       String @id @default(uuid())
  name     String
  price    Int    @default(0)
  quota    Int
  eventId  String @map("event_id")

  event         Event          @relation(fields: [eventId], references: [id])
  registrations Registration[]

  @@index([eventId])
  @@map("ticket_types")
}

model Registration {
  id             String             @id @default(uuid())
  status         RegistrationStatus @default(PENDING)
  userId         String             @map("user_id")
  eventId        String             @map("event_id")
  ticketTypeId   String             @map("ticket_type_id")
  organizationId String             @map("organization_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id])
  event        Event        @relation(fields: [eventId], references: [id])
  ticketType   TicketType   @relation(fields: [ticketTypeId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  checkIn      CheckIn?

  @@index([organizationId, status])
  @@index([eventId])
  @@index([ticketTypeId])
  @@map("registrations")
}

model CheckIn {
  id             String   @id @default(uuid())
  registrationId String   @unique @map("registration_id")
  checkedInAt    DateTime @default(now()) @map("checked_in_at")

  registration Registration @relation(fields: [registrationId], references: [id])

  @@map("check_ins")
}

model AuditLog {
  id             String   @id @default(uuid())
  action         String
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  organizationId String   @map("organization_id")
  userId         String?  @map("user_id")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}
