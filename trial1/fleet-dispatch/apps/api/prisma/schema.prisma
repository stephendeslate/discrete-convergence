generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN      @map("admin")
  DISPATCHER @map("dispatcher")
  TECHNICIAN @map("technician")
  CUSTOMER   @map("customer")

  @@map("user_role")
}

enum WorkOrderStatus {
  UNASSIGNED  @map("unassigned")
  ASSIGNED    @map("assigned")
  EN_ROUTE    @map("en_route")
  ON_SITE     @map("on_site")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")
  INVOICED    @map("invoiced")
  PAID        @map("paid")
  CANCELLED   @map("cancelled")

  @@map("work_order_status")
}

enum InvoiceStatus {
  DRAFT @map("draft")
  SENT  @map("sent")
  PAID  @map("paid")
  VOID  @map("void")

  @@map("invoice_status")
}

enum Priority {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")
  URGENT @map("urgent")

  @@map("priority")
}

enum RouteStatus {
  PLANNED     @map("planned")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")

  @@map("route_status")
}

enum NotificationType {
  ASSIGNMENT    @map("assignment")
  STATUS_CHANGE @map("status_change")
  INVOICE       @map("invoice")
  SYSTEM        @map("system")

  @@map("notification_type")
}

model Company {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  technicians   Technician[]
  customers     Customer[]
  workOrders    WorkOrder[]
  invoices      Invoice[]
  routes        Route[]
  notifications Notification[]
  auditLogs     AuditLog[]
  settings      Setting[]

  @@map("companies")
}

model User {
  id           String   @id @default(uuid())
  email        String   @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  role         UserRole
  isActive     Boolean  @default(true) @map("is_active")
  companyId    String   @map("company_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company       Company        @relation(fields: [companyId], references: [id])
  notifications Notification[]

  @@unique([email, companyId])
  @@index([companyId])
  @@map("users")
}

model Technician {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  skills    String[] @default([])
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  isActive  Boolean  @default(true) @map("is_active")
  companyId String   @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]
  routes     Route[]

  @@index([companyId])
  @@map("technicians")
}

model Customer {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  address   String?  @db.VarChar(500)
  companyId String   @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]
  invoices   Invoice[]

  @@index([companyId])
  @@map("customers")
}

model WorkOrder {
  id           String          @id @default(uuid())
  title        String          @db.VarChar(255)
  description  String?         @db.Text
  status       WorkOrderStatus @default(UNASSIGNED)
  priority     Priority        @default(MEDIUM)
  scheduledAt  DateTime?       @map("scheduled_at")
  completedAt  DateTime?       @map("completed_at")
  technicianId String?         @map("technician_id")
  customerId   String?         @map("customer_id")
  companyId    String          @map("company_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  technician Technician? @relation(fields: [technicianId], references: [id])
  customer   Customer?   @relation(fields: [customerId], references: [id])
  invoice    Invoice?
  photos     Photo[]
  routeStops RouteStop[]

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@map("work_orders")
}

model Invoice {
  id          String        @id @default(uuid())
  status      InvoiceStatus @default(DRAFT)
  subtotal    Decimal       @default(0) @db.Decimal(12, 2)
  tax         Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  dueDate     DateTime?     @map("due_date")
  sentAt      DateTime?     @map("sent_at")
  paidAt      DateTime?     @map("paid_at")
  workOrderId String        @unique @map("work_order_id")
  customerId  String        @map("customer_id")
  companyId   String        @map("company_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workOrder Company   @relation(fields: [companyId], references: [id])
  customer  Customer  @relation(fields: [customerId], references: [id])
  order     WorkOrder @relation(fields: [workOrderId], references: [id])
  lineItems LineItem[]

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@map("invoices")
}

model LineItem {
  id          String  @id @default(uuid())
  description String  @db.VarChar(500)
  quantity    Int     @default(1)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)
  invoiceId   String  @map("invoice_id")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("line_items")
}

model Route {
  id            String      @id @default(uuid())
  date          DateTime    @db.Date
  status        RouteStatus @default(PLANNED)
  totalDistance  Decimal?    @map("total_distance") @db.Decimal(12, 2)
  totalDuration Int?        @map("total_duration")
  technicianId  String      @map("technician_id")
  companyId     String      @map("company_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  technician Technician  @relation(fields: [technicianId], references: [id])
  stops      RouteStop[]

  @@index([companyId])
  @@map("routes")
}

model RouteStop {
  id          String @id @default(uuid())
  orderIndex  Int    @map("order_index")
  routeId     String @map("route_id")
  workOrderId String @map("work_order_id")

  route     Route     @relation(fields: [routeId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([routeId])
  @@map("route_stops")
}

model Photo {
  id          String   @id @default(uuid())
  url         String   @db.VarChar(1000)
  caption     String?  @db.VarChar(500)
  workOrderId String   @map("work_order_id")
  createdAt   DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@map("photos")
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id")
  action     String   @db.VarChar(50)
  before     Json?
  after      Json?
  userId     String?  @map("user_id")
  companyId  String   @map("company_id")
  createdAt  DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String           @db.VarChar(255)
  body      String?          @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  userId    String           @map("user_id")
  companyId String           @map("company_id")
  createdAt DateTime         @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@map("notifications")
}

model Setting {
  id        String @id @default(uuid())
  key       String @db.VarChar(255)
  value     String @db.Text
  companyId String @map("company_id")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([key, companyId])
  @@index([companyId])
  @@map("settings")
}
