// Prisma schema with snake_case mapping and RLS indexes
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantTier {
  FREE       @map("free")
  PRO        @map("pro")
  ENTERPRISE @map("enterprise")

  @@map("tenant_tier")
}

enum EventStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  CANCELLED @map("cancelled")
  COMPLETED @map("completed")

  @@map("event_status")
}

enum RegistrationStatus {
  CONFIRMED  @map("confirmed")
  CANCELLED  @map("cancelled")
  WAITLISTED @map("waitlisted")

  @@map("registration_status")
}

enum UserRole {
  ADMIN  @map("admin")
  MEMBER @map("member")

  @@map("user_role")
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Tenant {
  id        String     @id @default(uuid()) @map("id")
  name      String     @map("name")
  slug      String     @unique @map("slug")
  tier      TenantTier @default(FREE) @map("tier")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  users     User[]
  events    Event[]
  venues    Venue[]
  auditLogs AuditLog[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid()) @map("id")
  email        String   @map("email")
  passwordHash String   @map("password_hash")
  tenantId     String   @map("tenant_id")
  role         UserRole @default(MEMBER) @map("role")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@map("users")
}

model Event {
  id          String      @id @default(uuid()) @map("id")
  tenantId    String      @map("tenant_id")
  name        String      @map("name")
  description String?     @map("description")
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  status      EventStatus @default(DRAFT) @map("status")
  venueId     String?     @map("venue_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  venue         Venue?         @relation(fields: [venueId], references: [id])
  ticketTypes   TicketType[]
  registrations Registration[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([venueId])
  @@map("events")
}

model Venue {
  id        String   @id @default(uuid()) @map("id")
  tenantId  String   @map("tenant_id")
  name      String   @map("name")
  address   String   @map("address")
  capacity  Int      @map("capacity")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  events Event[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@map("venues")
}

model TicketType {
  id        String   @id @default(uuid()) @map("id")
  eventId   String   @map("event_id")
  name      String   @map("name")
  price     Decimal  @db.Decimal(10, 2) @map("price")
  quantity  Int      @map("quantity")
  sold      Int      @default(0) @map("sold")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event         Event          @relation(fields: [eventId], references: [id])
  registrations Registration[]

  @@index([eventId])
  @@map("ticket_types")
}

model Registration {
  id            String             @id @default(uuid()) @map("id")
  eventId       String             @map("event_id")
  ticketTypeId  String             @map("ticket_type_id")
  attendeeName  String             @map("attendee_name")
  attendeeEmail String             @map("attendee_email")
  status        RegistrationStatus @default(CONFIRMED) @map("status")
  createdAt     DateTime           @default(now()) @map("created_at")

  event      Event      @relation(fields: [eventId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([eventId])
  @@index([ticketTypeId])
  @@index([eventId, status])
  @@map("registrations")
}

model AuditLog {
  id        String   @id @default(uuid()) @map("id")
  tenantId  String   @map("tenant_id")
  action    String   @map("action")
  entity    String   @map("entity")
  entityId  String   @map("entity_id")
  userId    String?  @map("user_id")
  metadata  String?  @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, entity])
  @@index([userId])
  @@map("audit_logs")
}
