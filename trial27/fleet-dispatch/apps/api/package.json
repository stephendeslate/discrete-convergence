    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.6.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0",
    "source-map-support": "^0.5.21"
