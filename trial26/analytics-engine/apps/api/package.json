{
  "name": "@analytics-engine/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm exec prisma generate && nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest --testPathPattern='src/' --forceExit --passWithNoTests --coverage",
    "test:integration": "jest --config jest.config.js --testPathPattern=test/ --forceExit"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/config": "^4.0.0",
    "@prisma/client": "^6.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "bcryptjs": "^2.4.3",
    "helmet": "^8.0.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "@analytics-engine/shared": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.0",
    "supertest": "^7.0.0",
    "typescript": "^5.7.0",
    "prisma": "^6.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "jscpd": "^4.0.0",
    "source-map-support": "^0.5.21",
    "tsconfig-paths": "^4.2.0"
  }
}
