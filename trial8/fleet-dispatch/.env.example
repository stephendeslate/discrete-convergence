# Database
DATABASE_URL=postgresql://fleet:fleet_password@localhost:5432/fleet_dispatch?connection_limit=10
POSTGRES_USER=fleet
POSTGRES_PASSWORD=fleet_password
POSTGRES_DB=fleet_dispatch

# Auth
JWT_SECRET=change-me-in-production-minimum-32-chars
BCRYPT_SALT_ROUNDS=12

# App
PORT=3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development
APP_VERSION=1.0.0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
