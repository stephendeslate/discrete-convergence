generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN @map("admin")
  USER  @map("user")
  VIEWER @map("viewer")

  @@map("user_role")
}

enum WidgetType {
  CHART     @map("chart")
  TABLE     @map("table")
  METRIC    @map("metric")
  MAP       @map("map")

  @@map("widget_type")
}

enum DataSourceType {
  POSTGRESQL @map("postgresql")
  MYSQL      @map("mysql")
  REST_API   @map("rest_api")
  CSV        @map("csv")

  @@map("data_source_type")
}

enum DashboardStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  ARCHIVED  @map("archived")

  @@map("dashboard_status")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         UserRole  @default(USER)
  tenantId     String    @map("tenant_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  dashboards   Dashboard[]

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Dashboard {
  id          String          @id @default(uuid())
  title       String
  description String?
  status      DashboardStatus @default(DRAFT)
  tenantId    String          @map("tenant_id")
  userId      String          @map("user_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user        User            @relation(fields: [userId], references: [id])
  widgets     Widget[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([userId])
  @@map("dashboards")
}

model Widget {
  id           String     @id @default(uuid())
  title        String
  type         WidgetType
  config       String     @default("{}")
  position     Int        @default(0)
  tenantId     String     @map("tenant_id")
  dashboardId  String     @map("dashboard_id")
  dataSourceId String?    @map("data_source_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  dashboard    Dashboard  @relation(fields: [dashboardId], references: [id])
  dataSource   DataSource? @relation(fields: [dataSourceId], references: [id])

  @@index([tenantId])
  @@index([dashboardId])
  @@index([dataSourceId])
  @@index([tenantId, type])
  @@map("widgets")
}

model DataSource {
  id             String         @id @default(uuid())
  name           String
  type           DataSourceType
  connectionUrl  String         @map("connection_url")
  tenantId       String         @map("tenant_id")
  isActive       Boolean        @default(true) @map("is_active")
  lastSyncAt     DateTime?      @map("last_sync_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  widgets        Widget[]

  @@index([tenantId])
  @@index([isActive])
  @@index([tenantId, isActive])
  @@map("data_sources")
}

model Metric {
  id          String   @id @default(uuid())
  name        String
  value       Decimal  @db.Decimal(12, 2)
  unit        String?
  tenantId    String   @map("tenant_id")
  dataSourceId String? @map("data_source_id")
  recordedAt  DateTime @default(now()) @map("recorded_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([recordedAt])
  @@index([tenantId, name])
  @@map("metrics")
}
