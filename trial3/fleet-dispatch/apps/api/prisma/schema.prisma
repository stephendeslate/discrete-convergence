generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN       @map("admin")
  DISPATCHER  @map("dispatcher")
  TECHNICIAN  @map("technician")
  CUSTOMER    @map("customer")

  @@map("user_role")
}

enum WorkOrderStatus {
  UNASSIGNED   @map("unassigned")
  ASSIGNED     @map("assigned")
  EN_ROUTE     @map("en_route")
  ON_SITE      @map("on_site")
  IN_PROGRESS  @map("in_progress")
  COMPLETED    @map("completed")
  INVOICED     @map("invoiced")
  PAID         @map("paid")
  CANCELLED    @map("cancelled")

  @@map("work_order_status")
}

enum WorkOrderPriority {
  LOW      @map("low")
  MEDIUM   @map("medium")
  HIGH     @map("high")
  URGENT   @map("urgent")

  @@map("work_order_priority")
}

enum InvoiceStatus {
  DRAFT  @map("draft")
  SENT   @map("sent")
  PAID   @map("paid")
  VOID   @map("void")

  @@map("invoice_status")
}

enum LineItemType {
  LABOR     @map("labor")
  MATERIAL  @map("material")
  FLAT_RATE @map("flat_rate")
  DISCOUNT  @map("discount")
  TAX       @map("tax")

  @@map("line_item_type")
}

enum NotificationType {
  ASSIGNMENT   @map("assignment")
  EN_ROUTE     @map("en_route")
  COMPLETION   @map("completion")
  INVOICE      @map("invoice")

  @@map("notification_type")
}

model Company {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users        User[]
  technicians  Technician[]
  customers    Customer[]
  workOrders   WorkOrder[]
  routes       Route[]
  invoices     Invoice[]
  notifications Notification[]
  auditLogs    AuditLog[]

  @@map("companies")
}

model User {
  id            String   @id @default(uuid())
  email         String   @db.VarChar(255)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  firstName     String   @map("first_name") @db.VarChar(100)
  lastName      String   @map("last_name") @db.VarChar(100)
  role          UserRole
  companyId     String   @map("company_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  technician Technician?
  customer   Customer?

  @@unique([email, companyId])
  @@index([companyId])
  @@index([role])
  @@index([companyId, role])
  @@map("users")
}

model Technician {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  companyId   String   @map("company_id")
  skills      String[] @default([])
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id])
  company    Company     @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]
  routes     Route[]

  @@index([companyId])
  @@index([isAvailable])
  @@index([companyId, isAvailable])
  @@map("technicians")
}

model Customer {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  companyId   String   @map("company_id")
  phone       String?  @db.VarChar(20)
  address     String?  @db.VarChar(500)
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id])
  company    Company     @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]

  @@index([companyId])
  @@map("customers")
}

model WorkOrder {
  id            String            @id @default(uuid())
  companyId     String            @map("company_id")
  title         String            @db.VarChar(255)
  description   String?           @db.Text
  status        WorkOrderStatus   @default(UNASSIGNED)
  priority      WorkOrderPriority @default(MEDIUM)
  technicianId  String?           @map("technician_id")
  customerId    String?           @map("customer_id")
  scheduledAt   DateTime?         @map("scheduled_at")
  completedAt   DateTime?         @map("completed_at")
  address       String?           @db.VarChar(500)
  latitude      Decimal?          @db.Decimal(10, 7)
  longitude     Decimal?          @db.Decimal(10, 7)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  company       Company                  @relation(fields: [companyId], references: [id])
  technician    Technician?              @relation(fields: [technicianId], references: [id])
  customer      Customer?                @relation(fields: [customerId], references: [id])
  statusHistory WorkOrderStatusHistory[]
  routeStops    RouteStop[]
  photos        JobPhoto[]
  invoice       Invoice?

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@index([technicianId])
  @@index([customerId])
  @@map("work_orders")
}

model WorkOrderStatusHistory {
  id          String          @id @default(uuid())
  workOrderId String          @map("work_order_id")
  fromStatus  WorkOrderStatus @map("from_status")
  toStatus    WorkOrderStatus @map("to_status")
  changedBy   String          @map("changed_by")
  note        String?         @db.Text
  createdAt   DateTime        @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@map("work_order_status_history")
}

model Route {
  id            String    @id @default(uuid())
  companyId     String    @map("company_id")
  technicianId  String    @map("technician_id")
  date          DateTime  @db.Date
  totalDistance  Decimal   @default(0) @map("total_distance") @db.Decimal(12, 2)
  totalDuration Int       @default(0) @map("total_duration")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  technician Technician  @relation(fields: [technicianId], references: [id])
  stops      RouteStop[]

  @@index([companyId])
  @@index([technicianId])
  @@index([companyId, date])
  @@map("routes")
}

model RouteStop {
  id          String   @id @default(uuid())
  routeId     String   @map("route_id")
  workOrderId String   @map("work_order_id")
  stopOrder   Int      @map("stop_order")
  eta         DateTime?
  legDistance  Decimal  @default(0) @map("leg_distance") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  route     Route     @relation(fields: [routeId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([routeId])
  @@map("route_stops")
}

model JobPhoto {
  id          String   @id @default(uuid())
  workOrderId String   @map("work_order_id")
  url         String   @db.VarChar(1000)
  caption     String?  @db.VarChar(500)
  takenAt     DateTime @default(now()) @map("taken_at")
  createdAt   DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@map("job_photos")
}

model Invoice {
  id          String        @id @default(uuid())
  companyId   String        @map("company_id")
  workOrderId String        @unique @map("work_order_id")
  status      InvoiceStatus @default(DRAFT)
  totalAmount Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  issuedAt    DateTime?     @map("issued_at")
  paidAt      DateTime?     @map("paid_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id])
  workOrder WorkOrder  @relation(fields: [workOrderId], references: [id])
  lineItems LineItem[]

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@map("invoices")
}

model LineItem {
  id          String       @id @default(uuid())
  invoiceId   String       @map("invoice_id")
  type        LineItemType
  description String       @db.VarChar(500)
  quantity    Decimal      @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal      @map("unit_price") @db.Decimal(12, 2)
  total       Decimal      @db.Decimal(12, 2)
  createdAt   DateTime     @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("line_items")
}

model Notification {
  id          String           @id @default(uuid())
  companyId   String           @map("company_id")
  type        NotificationType
  recipientId String           @map("recipient_id")
  message     String           @db.Text
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([recipientId])
  @@index([companyId, recipientId])
  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  entityType  String   @map("entity_type") @db.VarChar(100)
  entityId    String   @map("entity_id")
  action      String   @db.VarChar(50)
  changes     Json?
  performedBy String   @map("performed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([companyId, entityType])
  @@map("audit_logs")
}
