# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fleet_dispatch

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=3600

# App
PORT=3000
NODE_ENV=development
APP_VERSION=1.0.0

# CORS
CORS_ORIGIN=http://localhost:3001

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
