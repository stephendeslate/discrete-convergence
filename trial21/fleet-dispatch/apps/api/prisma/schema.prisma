generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DISPATCHER
  TECHNICIAN
  CUSTOMER

  @@map("user_role")
}

enum WorkOrderStatus {
  UNASSIGNED
  ASSIGNED
  EN_ROUTE
  ON_SITE
  IN_PROGRESS
  COMPLETED
  INVOICED
  PAID
  CANCELLED

  @@map("work_order_status")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID

  @@map("invoice_status")
}

enum LineItemType {
  LABOR
  MATERIAL
  FLAT_RATE
  DISCOUNT
  TAX

  @@map("line_item_type")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users      User[]
  technicians Technician[]
  customers  Customer[]
  workOrders WorkOrder[]
  invoices   Invoice[]
  routes     Route[]
  auditLogs  AuditLog[]

  woSequence  Int @default(0) @map("wo_sequence")
  invSequence Int @default(0) @map("inv_sequence")

  @@map("companies")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole
  companyId    String   @map("company_id")
  tenantId     String   @map("tenant_id") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company       Company        @relation(fields: [companyId], references: [id])
  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([companyId])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Technician {
  id         String   @id @default(uuid())
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  email      String   @unique
  phone      String?
  skills     String[] @default([])
  latitude   Decimal? @db.Decimal(10, 7)
  longitude  Decimal? @db.Decimal(10, 7)
  gpsUpdatedAt DateTime? @map("gps_updated_at")
  isActive   Boolean  @default(true) @map("is_active")
  companyId  String   @map("company_id")
  tenantId   String   @map("tenant_id") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company    Company      @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]
  routeStops RouteStop[]

  @@index([companyId])
  @@index([tenantId])
  @@map("technicians")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  magicToken    String?  @map("magic_token")
  tokenExpiry   DateTime? @map("token_expiry")
  companyId String   @map("company_id")
  tenantId  String   @map("tenant_id") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]

  @@index([companyId])
  @@index([tenantId])
  @@map("customers")
}

model WorkOrder {
  id             String          @id @default(uuid())
  sequenceNumber String          @map("sequence_number")
  title          String
  description    String?
  status         WorkOrderStatus @default(UNASSIGNED)
  priority       Int             @default(3)
  scheduledDate  DateTime?       @map("scheduled_date")
  completedDate  DateTime?       @map("completed_date")
  latitude       Decimal?        @db.Decimal(10, 7)
  longitude      Decimal?        @db.Decimal(10, 7)
  trackingToken  String?         @unique @map("tracking_token")
  tokenExpiry    DateTime?       @map("token_expiry")
  companyId      String          @map("company_id")
  tenantId       String          @map("tenant_id") @db.Text
  technicianId   String?         @map("technician_id")
  customerId     String?         @map("customer_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  company        Company              @relation(fields: [companyId], references: [id])
  technician     Technician?          @relation(fields: [technicianId], references: [id])
  customer       Customer?            @relation(fields: [customerId], references: [id])
  statusHistory  WorkOrderStatusHistory[]
  photos         JobPhoto[]
  invoice        Invoice?
  routeStops     RouteStop[]

  @@index([companyId])
  @@index([tenantId])
  @@index([technicianId])
  @@index([customerId])
  @@index([status])
  @@map("work_orders")
}

model WorkOrderStatusHistory {
  id          String          @id @default(uuid())
  workOrderId String          @map("work_order_id")
  fromStatus  WorkOrderStatus? @map("from_status")
  toStatus    WorkOrderStatus @map("to_status")
  changedBy   String?         @map("changed_by")
  note        String?
  createdAt   DateTime        @default(now()) @map("created_at")

  workOrder   WorkOrder       @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@map("work_order_status_history")
}

model Route {
  id           String      @id @default(uuid())
  date         DateTime    @db.Date
  companyId    String      @map("company_id")
  tenantId     String      @map("tenant_id") @db.Text
  optimizedAt  DateTime?   @map("optimized_at")
  totalDistance Decimal?    @map("total_distance") @db.Decimal(12, 2)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  company      Company     @relation(fields: [companyId], references: [id])
  stops        RouteStop[]

  @@index([companyId])
  @@index([tenantId])
  @@index([date])
  @@map("routes")
}

model RouteStop {
  id           String    @id @default(uuid())
  routeId      String    @map("route_id")
  workOrderId  String    @map("work_order_id")
  technicianId String    @map("technician_id")
  stopOrder    Int       @map("stop_order")
  estimatedArrival DateTime? @map("estimated_arrival")
  createdAt    DateTime  @default(now()) @map("created_at")

  route        Route      @relation(fields: [routeId], references: [id])
  workOrder    WorkOrder  @relation(fields: [workOrderId], references: [id])
  technician   Technician @relation(fields: [technicianId], references: [id])

  @@index([routeId])
  @@map("route_stops")
}

model JobPhoto {
  id          String    @id @default(uuid())
  workOrderId String    @map("work_order_id")
  url         String
  caption     String?
  uploadedBy  String    @map("uploaded_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@map("job_photos")
}

model Invoice {
  id             String        @id @default(uuid())
  sequenceNumber String        @map("sequence_number")
  workOrderId    String        @unique @map("work_order_id")
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  tax            Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @default(0) @db.Decimal(12, 2)
  sentAt         DateTime?     @map("sent_at")
  paidAt         DateTime?     @map("paid_at")
  companyId      String        @map("company_id")
  tenantId       String        @map("tenant_id") @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  workOrder      WorkOrder     @relation(fields: [workOrderId], references: [id])
  company        Company       @relation(fields: [companyId], references: [id])
  lineItems      LineItem[]

  @@index([companyId])
  @@index([tenantId])
  @@index([status])
  @@map("invoices")
}

model LineItem {
  id          String       @id @default(uuid())
  invoiceId   String       @map("invoice_id")
  type        LineItemType
  description String
  quantity    Decimal      @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal      @map("unit_price") @db.Decimal(12, 2)
  total       Decimal      @db.Decimal(12, 2)
  createdAt   DateTime     @default(now()) @map("created_at")

  invoice     Invoice      @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("line_items")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   String?
  companyId String   @map("company_id")
  tenantId  String   @map("tenant_id") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([tenantId])
  @@index([createdAt])
  @@map("audit_logs")
}

model GpsReading {
  id           String   @id @default(uuid())
  technicianId String   @map("technician_id")
  latitude     Decimal  @db.Decimal(10, 7)
  longitude    Decimal  @db.Decimal(10, 7)
  accuracy     Decimal? @db.Decimal(8, 2)
  tenantId     String   @map("tenant_id") @db.Text
  recordedAt   DateTime @default(now()) @map("recorded_at")

  @@index([technicianId])
  @@index([tenantId])
  @@index([recordedAt])
  @@map("gps_readings")
}
