generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN     @map("admin")
  ORGANIZER @map("organizer")
  ATTENDEE  @map("attendee")

  @@map("user_role")
}

enum EventStatus {
  DRAFT               @map("draft")
  PUBLISHED           @map("published")
  REGISTRATION_OPEN   @map("registration_open")
  REGISTRATION_CLOSED @map("registration_closed")
  IN_PROGRESS         @map("in_progress")
  COMPLETED           @map("completed")
  ARCHIVED            @map("archived")
  CANCELLED           @map("cancelled")

  @@map("event_status")
}

enum RegistrationStatus {
  PENDING    @map("pending")
  CONFIRMED  @map("confirmed")
  CHECKED_IN @map("checked_in")
  CANCELLED  @map("cancelled")
  WAITLISTED @map("waitlisted")
  PROMOTED   @map("promoted")

  @@map("registration_status")
}

enum FieldType {
  TEXT     @map("text")
  EMAIL    @map("email")
  PHONE    @map("phone")
  SELECT   @map("select")
  CHECKBOX @map("checkbox")

  @@map("field_type")
}

enum NotificationStatus {
  PENDING   @map("pending")
  SENT      @map("sent")
  FAILED    @map("failed")
  DELIVERED @map("delivered")

  @@map("notification_status")
}

model Organization {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                 User[]
  events                Event[]
  venues                Venue[]
  notificationTemplates NotificationTemplate[]
  auditLogs             AuditLog[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  email          String   @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  name           String   @db.VarChar(255)
  role           UserRole @default(ATTENDEE)
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id])
  registrations  Registration[]
  checkIns       CheckIn[]
  auditLogs      AuditLog[]

  @@unique([email, organizationId])
  @@index([organizationId])
  @@map("users")
}

model Event {
  id             String      @id @default(uuid())
  title          String      @db.VarChar(255)
  description    String?     @db.Text
  slug           String      @db.VarChar(255)
  status         EventStatus @default(DRAFT)
  startDate      DateTime    @map("start_date")
  endDate        DateTime    @map("end_date")
  timezone       String      @default("UTC") @db.VarChar(50)
  capacity       Int         @default(0)
  organizationId String      @map("organization_id")
  venueId        String?     @map("venue_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization       Organization        @relation(fields: [organizationId], references: [id])
  venue              Venue?              @relation(fields: [venueId], references: [id])
  sessions           EventSession[]
  ticketTypes        TicketType[]
  registrations      Registration[]
  registrationFields RegistrationField[]
  waitlistEntries    WaitlistEntry[]
  notifications      Notification[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([status])
  @@index([organizationId, status])
  @@map("events")
}

model EventSession {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(255)
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  track     String?  @db.VarChar(100)
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_sessions")
}

model Venue {
  id             String  @id @default(uuid())
  name           String  @db.VarChar(255)
  address        String? @db.VarChar(500)
  city           String? @db.VarChar(100)
  capacity       Int     @default(0)
  isVirtual      Boolean @default(false) @map("is_virtual")
  organizationId String  @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  events       Event[]

  @@index([organizationId])
  @@map("venues")
}

model TicketType {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  price     Int      @default(0)
  quota     Int      @default(0)
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations Registration[]

  @@index([eventId])
  @@map("ticket_types")
}

model Registration {
  id             String             @id @default(uuid())
  status         RegistrationStatus @default(PENDING)
  userId         String             @map("user_id")
  eventId        String             @map("event_id")
  ticketTypeId   String?            @map("ticket_type_id")
  organizationId String             @map("organization_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id])
  event      Event       @relation(fields: [eventId], references: [id])
  ticketType TicketType? @relation(fields: [ticketTypeId], references: [id])
  checkIn    CheckIn?
  fieldValues RegistrationFieldValue[]

  @@index([eventId])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([organizationId, status])
  @@map("registrations")
}

model RegistrationField {
  id        String    @id @default(uuid())
  label     String    @db.VarChar(255)
  fieldType FieldType @map("field_type")
  required  Boolean   @default(false)
  options   String?   @db.Text
  eventId   String    @map("event_id")
  createdAt DateTime  @default(now()) @map("created_at")

  event       Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fieldValues RegistrationFieldValue[]

  @@index([eventId])
  @@map("registration_fields")
}

model RegistrationFieldValue {
  id                  String @id @default(uuid())
  value               String @db.Text
  registrationId      String @map("registration_id")
  registrationFieldId String @map("registration_field_id")

  registration      Registration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationField RegistrationField @relation(fields: [registrationFieldId], references: [id])

  @@index([registrationId])
  @@map("registration_field_values")
}

model CheckIn {
  id             String   @id @default(uuid())
  registrationId String   @unique @map("registration_id")
  checkedInBy    String   @map("checked_in_by")
  checkedInAt    DateTime @default(now()) @map("checked_in_at")

  registration Registration @relation(fields: [registrationId], references: [id])
  user         User         @relation(fields: [checkedInBy], references: [id])

  @@map("check_ins")
}

model WaitlistEntry {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  position  Int
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@map("waitlist_entries")
}

model Notification {
  id        String             @id @default(uuid())
  subject   String             @db.VarChar(255)
  body      String             @db.Text
  status    NotificationStatus @default(PENDING)
  eventId   String             @map("event_id")
  createdAt DateTime           @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@index([status])
  @@map("notifications")
}

model NotificationTemplate {
  id             String @id @default(uuid())
  name           String @db.VarChar(255)
  subject        String @db.VarChar(255)
  body           String @db.Text
  organizationId String @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("notification_templates")
}

model AuditLog {
  id             String   @id @default(uuid())
  action         String   @db.VarChar(255)
  entityType     String   @map("entity_type") @db.VarChar(100)
  entityId       String   @map("entity_id") @db.VarChar(36)
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  metadata       String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, entityType])
  @@map("audit_logs")
}
