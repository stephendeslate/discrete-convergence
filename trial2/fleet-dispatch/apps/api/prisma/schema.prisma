generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN       @map("admin")
  DISPATCHER  @map("dispatcher")
  TECHNICIAN  @map("technician")
  CUSTOMER    @map("customer")

  @@map("user_role")
}

enum WorkOrderStatus {
  UNASSIGNED   @map("unassigned")
  ASSIGNED     @map("assigned")
  EN_ROUTE     @map("en_route")
  ON_SITE      @map("on_site")
  IN_PROGRESS  @map("in_progress")
  COMPLETED    @map("completed")
  INVOICED     @map("invoiced")
  PAID         @map("paid")
  CANCELLED    @map("cancelled")

  @@map("work_order_status")
}

enum InvoiceStatus {
  DRAFT  @map("draft")
  SENT   @map("sent")
  PAID   @map("paid")
  VOID   @map("void")

  @@map("invoice_status")
}

enum Priority {
  LOW      @map("low")
  MEDIUM   @map("medium")
  HIGH     @map("high")
  URGENT   @map("urgent")

  @@map("priority")
}

enum LineItemType {
  LABOR     @map("labor")
  MATERIAL  @map("material")
  FLAT_RATE @map("flat_rate")
  DISCOUNT  @map("discount")
  TAX       @map("tax")

  @@map("line_item_type")
}

enum NotificationType {
  SMS    @map("sms")
  EMAIL  @map("email")
  PUSH   @map("push")

  @@map("notification_type")
}

model Company {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  address   String?  @db.VarChar(500)
  phone     String?  @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users        User[]
  technicians  Technician[]
  customers    Customer[]
  workOrders   WorkOrder[]
  routes       Route[]
  invoices     Invoice[]
  auditLogs    AuditLog[]
  notifications Notification[]

  @@map("companies")
}

model User {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  email        String   @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  role         UserRole @default(DISPATCHER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  technician Technician?

  @@unique([email])
  @@index([companyId])
  @@index([role])
  @@index([companyId, role])
  @@map("users")
}

model Technician {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  userId       String   @unique @map("user_id")
  skills       String[] @default([])
  isAvailable  Boolean  @default(true) @map("is_available")
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  lastGpsAt    DateTime? @map("last_gps_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  workOrders WorkOrder[]
  routes     Route[]

  @@index([companyId])
  @@index([isAvailable])
  @@index([companyId, isAvailable])
  @@map("technicians")
}

model Customer {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  address   String   @db.VarChar(500)
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]

  @@index([companyId])
  @@map("customers")
}

model WorkOrder {
  id            String          @id @default(uuid())
  companyId     String          @map("company_id")
  customerId    String          @map("customer_id")
  technicianId  String?         @map("technician_id")
  title         String          @db.VarChar(255)
  description   String?         @db.Text
  status        WorkOrderStatus @default(UNASSIGNED)
  priority      Priority        @default(MEDIUM)
  scheduledAt   DateTime?       @map("scheduled_at")
  completedAt   DateTime?       @map("completed_at")
  trackingToken String?         @unique @map("tracking_token") @db.VarChar(255)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  company       Company                 @relation(fields: [companyId], references: [id])
  customer      Customer                @relation(fields: [customerId], references: [id])
  technician    Technician?             @relation(fields: [technicianId], references: [id])
  statusHistory WorkOrderStatusHistory[]
  routeStops    RouteStop[]
  photos        JobPhoto[]
  invoice       Invoice?

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@index([technicianId])
  @@index([customerId])
  @@map("work_orders")
}

model WorkOrderStatusHistory {
  id          String          @id @default(uuid())
  workOrderId String          @map("work_order_id")
  fromStatus  WorkOrderStatus? @map("from_status")
  toStatus    WorkOrderStatus @map("to_status")
  changedBy   String          @map("changed_by")
  note        String?         @db.Text
  createdAt   DateTime        @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@map("work_order_status_history")
}

model Route {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  technicianId  String   @map("technician_id")
  date          DateTime @db.Date
  totalDistance  Decimal  @db.Decimal(12, 2)
  totalDuration Int      @map("total_duration")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  technician Technician  @relation(fields: [technicianId], references: [id])
  stops      RouteStop[]

  @@index([companyId])
  @@index([technicianId])
  @@index([companyId, date])
  @@map("routes")
}

model RouteStop {
  id          String   @id @default(uuid())
  routeId     String   @map("route_id")
  workOrderId String   @map("work_order_id")
  stopOrder   Int      @map("stop_order")
  eta         DateTime?
  legDistance  Decimal? @db.Decimal(12, 2) @map("leg_distance")
  createdAt   DateTime @default(now()) @map("created_at")

  route     Route     @relation(fields: [routeId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([routeId])
  @@map("route_stops")
}

model JobPhoto {
  id          String   @id @default(uuid())
  workOrderId String   @map("work_order_id")
  url         String   @db.VarChar(500)
  caption     String?  @db.VarChar(255)
  uploadedBy  String   @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@map("job_photos")
}

model Invoice {
  id          String        @id @default(uuid())
  companyId   String        @map("company_id")
  workOrderId String        @unique @map("work_order_id")
  invoiceNo   String        @map("invoice_no") @db.VarChar(50)
  status      InvoiceStatus @default(DRAFT)
  subtotal    Decimal       @db.Decimal(12, 2)
  tax         Decimal       @db.Decimal(12, 2)
  total       Decimal       @db.Decimal(12, 2)
  issuedAt    DateTime?     @map("issued_at")
  paidAt      DateTime?     @map("paid_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id])
  workOrder WorkOrder  @relation(fields: [workOrderId], references: [id])
  lineItems LineItem[]

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@map("invoices")
}

model LineItem {
  id          String       @id @default(uuid())
  invoiceId   String       @map("invoice_id")
  type        LineItemType
  description String       @db.VarChar(255)
  quantity    Decimal      @db.Decimal(12, 2)
  unitPrice   Decimal      @db.Decimal(12, 2) @map("unit_price")
  total       Decimal      @db.Decimal(12, 2)
  createdAt   DateTime     @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("line_items")
}

model Notification {
  id        String           @id @default(uuid())
  companyId String           @map("company_id")
  userId    String           @map("user_id")
  type      NotificationType
  subject   String           @db.VarChar(255)
  body      String           @db.Text
  sentAt    DateTime?        @map("sent_at")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  userId     String   @map("user_id")
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id")
  oldValue   String?  @map("old_value") @db.Text
  newValue   String?  @map("new_value") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([companyId, createdAt])
  @@map("audit_logs")
}
