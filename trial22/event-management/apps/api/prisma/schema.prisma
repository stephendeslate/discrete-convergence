generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN     @map("admin")
  USER      @map("user")
  ORGANIZER @map("organizer")

  @@map("user_role")
}

enum EventStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  CANCELLED @map("cancelled")
  COMPLETED @map("completed")

  @@map("event_status")
}

enum RegistrationStatus {
  PENDING   @map("pending")
  CONFIRMED @map("confirmed")
  CANCELLED @map("cancelled")
  WAITLISTED @map("waitlisted")

  @@map("registration_status")
}

enum TicketStatus {
  AVAILABLE  @map("available")
  SOLD       @map("sold")
  RESERVED   @map("reserved")
  CANCELLED  @map("cancelled")

  @@map("ticket_status")
}

enum SessionStatus {
  SCHEDULED @map("scheduled")
  ACTIVE    @map("active")
  COMPLETED @map("completed")
  CANCELLED @map("cancelled")

  @@map("session_status")
}

enum NotificationType {
  EMAIL     @map("email")
  SMS       @map("sms")
  PUSH      @map("push")

  @@map("notification_type")
}

enum SponsorTier {
  PLATINUM @map("platinum")
  GOLD     @map("gold")
  SILVER   @map("silver")
  BRONZE   @map("bronze")

  @@map("sponsor_tier")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  events        Event[]
  venues        Venue[]
  categories    Category[]
  speakers      Speaker[]
  sponsors      Sponsor[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @db.VarChar(255)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(255)
  role      UserRole @default(USER)
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  registrations Registration[]
  auditLogs     AuditLog[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Event {
  id          String      @id @default(uuid())
  title       String      @db.VarChar(500)
  description String?     @db.Text
  status      EventStatus @default(DRAFT)
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  capacity    Int         @default(0)
  tenantId    String      @map("tenant_id")
  venueId     String?     @map("venue_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  venue         Venue?         @relation(fields: [venueId], references: [id])
  ticketTypes   TicketType[]
  tickets       Ticket[]
  registrations Registration[]
  sessions      Session[]
  categories    Category[]     @relation("EventCategories")
  sponsors      Sponsor[]      @relation("EventSponsors")

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([venueId])
  @@map("events")
}

model Venue {
  id        String  @id @default(uuid())
  name      String  @db.VarChar(255)
  address   String  @db.VarChar(500)
  city      String  @db.VarChar(255)
  capacity  Int     @default(0)
  tenantId  String  @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  events Event[]

  @@index([tenantId])
  @@map("venues")
}

model TicketType {
  id        String  @id @default(uuid())
  name      String  @db.VarChar(255)
  price     Decimal @db.Decimal(12, 2)
  quantity  Int     @default(0)
  eventId   String  @map("event_id")
  tenantId  String  @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event   Event    @relation(fields: [eventId], references: [id])
  tickets Ticket[]

  @@index([eventId])
  @@index([tenantId])
  @@map("ticket_types")
}

model Ticket {
  id           String       @id @default(uuid())
  status       TicketStatus @default(AVAILABLE)
  price        Decimal      @db.Decimal(12, 2)
  eventId      String       @map("event_id")
  ticketTypeId String       @map("ticket_type_id")
  attendeeId   String?      @map("attendee_id")
  tenantId     String       @map("tenant_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  event      Event      @relation(fields: [eventId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  attendee   Attendee?  @relation(fields: [attendeeId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([eventId])
  @@map("tickets")
}

model Attendee {
  id        String   @id @default(uuid())
  email     String   @db.VarChar(255)
  name      String   @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tickets       Ticket[]
  registrations Registration[]

  @@index([tenantId])
  @@index([email])
  @@map("attendees")
}

model Registration {
  id         String             @id @default(uuid())
  status     RegistrationStatus @default(PENDING)
  eventId    String             @map("event_id")
  userId     String?            @map("user_id")
  attendeeId String?            @map("attendee_id")
  tenantId   String             @map("tenant_id")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  event    Event     @relation(fields: [eventId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  attendee Attendee? @relation(fields: [attendeeId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([eventId])
  @@map("registrations")
}

model Speaker {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  bio       String?  @db.Text
  email     String   @db.VarChar(255)
  company   String?  @db.VarChar(255)
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  sessions Session[]

  @@index([tenantId])
  @@map("speakers")
}

model Session {
  id        String        @id @default(uuid())
  title     String        @db.VarChar(500)
  description String?     @db.Text
  startTime DateTime      @map("start_time")
  endTime   DateTime      @map("end_time")
  status    SessionStatus @default(SCHEDULED)
  eventId   String        @map("event_id")
  speakerId String?       @map("speaker_id")
  tenantId  String        @map("tenant_id")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  event   Event    @relation(fields: [eventId], references: [id])
  speaker Speaker? @relation(fields: [speakerId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([eventId])
  @@map("sessions")
}

model Sponsor {
  id          String      @id @default(uuid())
  name        String      @db.VarChar(255)
  tier        SponsorTier @default(BRONZE)
  amount      Decimal     @db.Decimal(12, 2)
  contactEmail String     @db.VarChar(255) @map("contact_email")
  tenantId    String      @map("tenant_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  events Event[] @relation("EventSponsors")

  @@index([tenantId])
  @@map("sponsors")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  slug      String   @db.VarChar(100)
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  events Event[] @relation("EventCategories")

  @@unique([slug, tenantId])
  @@index([tenantId])
  @@map("categories")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType @default(EMAIL)
  subject   String           @db.VarChar(500)
  body      String           @db.Text
  sentAt    DateTime?        @map("sent_at")
  tenantId  String           @map("tenant_id")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   @db.VarChar(255)
  entity    String   @db.VarChar(255)
  entityId  String   @map("entity_id") @db.VarChar(255)
  userId    String?  @map("user_id")
  tenantId  String   @map("tenant_id")
  metadata  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user   User?  @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([entity, entityId])
  @@map("audit_logs")
}
