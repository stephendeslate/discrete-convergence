{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "incremental": true,
    "resolveJsonModule": true,
    "paths": {
      "@repo/shared": ["../../packages/shared/src"]
    },
    "types": ["jest", "node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "test"]
}
