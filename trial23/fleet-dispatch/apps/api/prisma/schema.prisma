generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  DISPATCHER
  TECHNICIAN
  CUSTOMER
}

enum WorkOrderStatus {
  UNASSIGNED
  ASSIGNED
  EN_ROUTE
  ON_SITE
  IN_PROGRESS
  COMPLETED
  INVOICED
  PAID
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  WORK_ORDER_ASSIGNED
  STATUS_CHANGED
  INVOICE_SENT
  ROUTE_UPDATED
  SYSTEM
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  domain    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  technicians Technician[]
  customers   Customer[]
  workOrders  WorkOrder[]
  routes      Route[]
  dashboards  Dashboard[]
  dataSources DataSource[]
  invoices    Invoice[]
  notifications Notification[]
  auditLogs   AuditLog[]

  @@map("companies")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole
  companyId    String   @map("company_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company       Company        @relation(fields: [companyId], references: [id])
  technician    Technician?
  notifications Notification[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Technician {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  specialties String[]
  isAvailable Boolean  @default(true) @map("is_available")
  rating      Decimal? @db.Decimal
  companyId   String   @map("company_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id])
  company    Company     @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]
  routes     Route[]

  @@index([companyId])
  @@map("technicians")
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  phone     String?
  address   String
  city      String
  state     String
  zipCode   String   @map("zip_code")
  companyId String   @map("company_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]

  @@index([companyId])
  @@index([email])
  @@map("customers")
}

model WorkOrder {
  id             String          @id @default(uuid()) @db.Uuid
  title          String
  description    String?
  status         WorkOrderStatus @default(UNASSIGNED)
  priority       Priority
  scheduledDate  DateTime?       @map("scheduled_date")
  completedDate  DateTime?       @map("completed_date")
  estimatedHours Decimal?        @map("estimated_hours") @db.Decimal
  actualHours    Decimal?        @map("actual_hours") @db.Decimal
  customerId     String          @map("customer_id") @db.Uuid
  technicianId   String?         @map("technician_id") @db.Uuid
  companyId      String          @map("company_id") @db.Uuid
  version        Int             @default(1)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  customer   Customer    @relation(fields: [customerId], references: [id])
  technician Technician? @relation(fields: [technicianId], references: [id])
  company    Company     @relation(fields: [companyId], references: [id])
  routeStops RouteStop[]
  invoices   Invoice[]
  jobPhotos  JobPhoto[]

  @@index([companyId])
  @@index([status])
  @@index([technicianId])
  @@index([customerId])
  @@map("work_orders")
}

model Route {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  date         DateTime
  technicianId String   @map("technician_id") @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  version      Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  technician Technician  @relation(fields: [technicianId], references: [id])
  company    Company     @relation(fields: [companyId], references: [id])
  stops      RouteStop[]

  @@index([companyId])
  @@map("routes")
}

model RouteStop {
  id               String    @id @default(uuid()) @db.Uuid
  routeId          String    @map("route_id") @db.Uuid
  workOrderId      String    @map("work_order_id") @db.Uuid
  sequenceOrder    Int       @map("sequence_order")
  estimatedArrival DateTime? @map("estimated_arrival")
  actualArrival    DateTime? @map("actual_arrival")
  createdAt        DateTime  @default(now()) @map("created_at")

  route     Route     @relation(fields: [routeId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([routeId])
  @@map("route_stops")
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @unique @map("invoice_number")
  workOrderId   String        @map("work_order_id") @db.Uuid
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal
  tax           Decimal       @db.Decimal
  total         Decimal       @db.Decimal
  dueDate       DateTime      @map("due_date")
  paidDate      DateTime?     @map("paid_date")
  companyId     String        @map("company_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  workOrder WorkOrder  @relation(fields: [workOrderId], references: [id])
  company   Company    @relation(fields: [companyId], references: [id])
  lineItems LineItem[]

  @@index([companyId])
  @@index([status])
  @@map("invoices")
}

model LineItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  description String
  quantity    Decimal  @db.Decimal
  unitPrice   Decimal  @map("unit_price") @db.Decimal
  total       Decimal  @db.Decimal
  createdAt   DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("line_items")
}

model JobPhoto {
  id          String   @id @default(uuid()) @db.Uuid
  workOrderId String   @map("work_order_id") @db.Uuid
  url         String
  caption     String?
  uploadedBy  String   @map("uploaded_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@map("job_photos")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  companyId String           @map("company_id") @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([companyId])
  @@map("notifications")
}

model Dashboard {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  layout      Json?
  companyId   String   @map("company_id") @db.Uuid
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company  @relation(fields: [companyId], references: [id])
  widgets Widget[]

  @@index([companyId])
  @@map("dashboards")
}

model Widget {
  id          String   @id @default(uuid()) @db.Uuid
  dashboardId String   @map("dashboard_id") @db.Uuid
  type        String
  title       String
  config      Json?
  position    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dashboard Dashboard @relation(fields: [dashboardId], references: [id])

  @@index([dashboardId])
  @@map("widgets")
}

model DataSource {
  id               String    @id @default(uuid()) @db.Uuid
  name             String
  type             String
  connectionConfig Json      @map("connection_config")
  isActive         Boolean   @default(true) @map("is_active")
  lastSyncAt       DateTime? @map("last_sync_at")
  companyId        String    @map("company_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("data_sources")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  userId     String?  @map("user_id") @db.Uuid
  changes    Json?
  companyId  String   @map("company_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
