# Database
DATABASE_URL=postgresql://analytics:analytics@localhost:5432/analytics_engine?connection_limit=10

# Auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRY=1h

# CORS
CORS_ORIGIN=http://localhost:3000

# Application
NODE_ENV=development
PORT=3001

# Encryption (for DataSource credentials)
ENCRYPTION_KEY=change-me-32-byte-hex-key-for-aes
