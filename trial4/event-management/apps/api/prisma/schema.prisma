generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN     @map("admin")
  ORGANIZER @map("organizer")
  ATTENDEE  @map("attendee")

  @@map("user_role")
}

enum EventStatus {
  DRAFT               @map("draft")
  PUBLISHED           @map("published")
  REGISTRATION_OPEN   @map("registration_open")
  REGISTRATION_CLOSED @map("registration_closed")
  IN_PROGRESS         @map("in_progress")
  COMPLETED           @map("completed")
  CANCELLED           @map("cancelled")
  ARCHIVED            @map("archived")

  @@map("event_status")
}

enum RegistrationStatus {
  PENDING    @map("pending")
  CONFIRMED  @map("confirmed")
  CANCELLED  @map("cancelled")
  WAITLISTED @map("waitlisted")
  PROMOTED   @map("promoted")
  CHECKED_IN @map("checked_in")

  @@map("registration_status")
}

enum FieldType {
  TEXT     @map("text")
  EMAIL    @map("email")
  PHONE    @map("phone")
  SELECT   @map("select")
  CHECKBOX @map("checkbox")

  @@map("field_type")
}

enum NotificationStatus {
  QUEUED    @map("queued")
  SENT      @map("sent")
  FAILED    @map("failed")
  DELIVERED @map("delivered")

  @@map("notification_status")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  tier      String   @default("FREE") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users  User[]
  events Event[]
  venues Venue[]
  auditLogs AuditLog[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  firstName      String   @map("first_name") @db.VarChar(100)
  lastName       String   @map("last_name") @db.VarChar(100)
  role           UserRole @default(ATTENDEE)
  organizationId String   @map("organization_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id])
  registrations Registration[]

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([role])
  @@index([organizationId, role])
  @@map("users")
}

model Event {
  id             String      @id @default(uuid()) @db.Uuid
  title          String      @db.VarChar(255)
  slug           String      @db.VarChar(255)
  description    String?     @db.Text
  status         EventStatus @default(DRAFT)
  timezone       String      @default("UTC") @db.VarChar(50)
  startDate      DateTime    @map("start_date")
  endDate        DateTime    @map("end_date")
  organizationId String      @map("organization_id") @db.Uuid
  venueId        String?     @map("venue_id") @db.Uuid
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization       Organization        @relation(fields: [organizationId], references: [id])
  venue              Venue?              @relation(fields: [venueId], references: [id])
  sessions           EventSession[]
  ticketTypes        TicketType[]
  registrations      Registration[]
  registrationFields RegistrationField[]
  notifications      Notification[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([status])
  @@index([organizationId, status])
  @@map("events")
}

model EventSession {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(255)
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  track     String?  @db.VarChar(100)
  eventId   String   @map("event_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@map("event_sessions")
}

model Venue {
  id             String  @id @default(uuid()) @db.Uuid
  name           String  @db.VarChar(255)
  address        String? @db.VarChar(500)
  capacity       Int
  isVirtual      Boolean @default(false) @map("is_virtual")
  organizationId String  @map("organization_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  events       Event[]

  @@index([organizationId])
  @@map("venues")
}

model TicketType {
  id        String  @id @default(uuid()) @db.Uuid
  name      String  @db.VarChar(100)
  price     Decimal @db.Decimal(12, 2)
  quota     Int
  sold      Int     @default(0)
  eventId   String  @map("event_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event         Event          @relation(fields: [eventId], references: [id])
  registrations Registration[]

  @@index([eventId])
  @@map("ticket_types")
}

model Registration {
  id           String             @id @default(uuid()) @db.Uuid
  status       RegistrationStatus @default(PENDING)
  userId       String             @map("user_id") @db.Uuid
  eventId      String             @map("event_id") @db.Uuid
  ticketTypeId String             @map("ticket_type_id") @db.Uuid
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id])
  event      Event      @relation(fields: [eventId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  checkIn    CheckIn?
  fieldValues RegistrationFieldValue[]
  waitlistEntry WaitlistEntry?

  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@index([eventId, status])
  @@map("registrations")
}

model RegistrationField {
  id       String    @id @default(uuid()) @db.Uuid
  label    String    @db.VarChar(255)
  type     FieldType @default(TEXT)
  required Boolean   @default(false)
  options  String?   @db.Text
  eventId  String    @map("event_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  event  Event                    @relation(fields: [eventId], references: [id])
  values RegistrationFieldValue[]

  @@index([eventId])
  @@map("registration_fields")
}

model RegistrationFieldValue {
  id               String @id @default(uuid()) @db.Uuid
  value            String @db.Text
  registrationId   String @map("registration_id") @db.Uuid
  registrationFieldId String @map("registration_field_id") @db.Uuid

  registration      Registration      @relation(fields: [registrationId], references: [id])
  registrationField RegistrationField @relation(fields: [registrationFieldId], references: [id])

  @@index([registrationId])
  @@map("registration_field_values")
}

model CheckIn {
  id             String   @id @default(uuid()) @db.Uuid
  checkedInAt    DateTime @default(now()) @map("checked_in_at")
  registrationId String   @unique @map("registration_id") @db.Uuid

  registration Registration @relation(fields: [registrationId], references: [id])

  @@map("check_ins")
}

model WaitlistEntry {
  id             String   @id @default(uuid()) @db.Uuid
  position       Int
  registrationId String   @unique @map("registration_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  registration Registration @relation(fields: [registrationId], references: [id])

  @@index([registrationId])
  @@map("waitlist_entries")
}

model Notification {
  id        String             @id @default(uuid()) @db.Uuid
  subject   String             @db.VarChar(500)
  body      String             @db.Text
  status    NotificationStatus @default(QUEUED)
  eventId   String             @map("event_id") @db.Uuid
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@index([status])
  @@map("notifications")
}

model NotificationTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  subject   String   @db.VarChar(500)
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_templates")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  action         String   @db.VarChar(100)
  entityType     String   @map("entity_type") @db.VarChar(100)
  entityId       String   @map("entity_id") @db.Uuid
  details        Json?
  organizationId String   @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([entityType])
  @@index([organizationId, entityType])
  @@map("audit_logs")
}
