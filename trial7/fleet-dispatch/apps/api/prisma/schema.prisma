generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN      @map("admin")
  DISPATCHER @map("dispatcher")
  DRIVER     @map("driver")
  VIEWER     @map("viewer")

  @@map("user_role")
}

enum VehicleStatus {
  AVAILABLE   @map("available")
  IN_USE      @map("in_use")
  MAINTENANCE @map("maintenance")
  RETIRED     @map("retired")

  @@map("vehicle_status")
}

enum DriverStatus {
  ACTIVE     @map("active")
  INACTIVE   @map("inactive")
  ON_LEAVE   @map("on_leave")
  TERMINATED @map("terminated")

  @@map("driver_status")
}

enum RouteStatus {
  PLANNED    @map("planned")
  ACTIVE     @map("active")
  COMPLETED  @map("completed")
  CANCELLED  @map("cancelled")

  @@map("route_status")
}

enum DispatchStatus {
  PENDING    @map("pending")
  ASSIGNED   @map("assigned")
  IN_TRANSIT @map("in_transit")
  DELIVERED  @map("delivered")
  FAILED     @map("failed")

  @@map("dispatch_status")
}

enum MaintenanceType {
  PREVENTIVE @map("preventive")
  CORRECTIVE @map("corrective")
  EMERGENCY  @map("emergency")

  @@map("maintenance_type")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  email        String   @unique
  passwordHash String
  role         UserRole @default(VIEWER)
  name         String   @db.VarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  dispatches Dispatch[]
  auditLogs  AuditLog[]

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  vehicles           Vehicle[]
  drivers            Driver[]
  routes             Route[]
  dispatches         Dispatch[]
  maintenanceRecords MaintenanceRecord[]
  auditLogs          AuditLog[]

  @@map("tenants")
}

model Vehicle {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @db.Uuid
  licensePlate   String        @db.VarChar(20)
  make           String        @db.VarChar(100)
  model          String        @db.VarChar(100)
  year           Int
  status         VehicleStatus @default(AVAILABLE)
  mileage        Decimal       @db.Decimal(12, 2)
  fuelCostPerKm  Decimal       @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  dispatches         Dispatch[]
  maintenanceRecords MaintenanceRecord[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@map("vehicles")
}

model Driver {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  name         String       @db.VarChar(255)
  licenseNumber String      @db.VarChar(50)
  phone        String       @db.VarChar(20)
  status       DriverStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  dispatches Dispatch[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@map("drivers")
}

model Route {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @db.Uuid
  name        String      @db.VarChar(255)
  origin      String      @db.VarChar(255)
  destination String      @db.VarChar(255)
  distanceKm  Decimal     @db.Decimal(12, 2)
  status      RouteStatus @default(PLANNED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  dispatches Dispatch[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@map("routes")
}

model Dispatch {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @db.Uuid
  vehicleId    String         @db.Uuid
  driverId     String         @db.Uuid
  routeId      String         @db.Uuid
  dispatcherId String         @db.Uuid
  status       DispatchStatus @default(PENDING)
  scheduledAt  DateTime
  completedAt  DateTime?
  notes        String?        @db.Text
  totalCost    Decimal        @db.Decimal(12, 2) @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  vehicle    Vehicle @relation(fields: [vehicleId], references: [id])
  driver     Driver  @relation(fields: [driverId], references: [id])
  route      Route   @relation(fields: [routeId], references: [id])
  dispatcher User    @relation(fields: [dispatcherId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([vehicleId])
  @@index([driverId])
  @@index([routeId])
  @@map("dispatches")
}

model MaintenanceRecord {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @db.Uuid
  vehicleId   String          @db.Uuid
  type        MaintenanceType
  description String          @db.Text
  cost        Decimal         @db.Decimal(12, 2)
  performedAt DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([vehicleId])
  @@index([tenantId, vehicleId])
  @@map("maintenance_records")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String   @db.Uuid
  metadata  String?  @db.Text
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, action])
  @@map("audit_logs")
}
